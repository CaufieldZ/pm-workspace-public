    "allowedTools": [
      "Read",
      "Write",
      "Glob",
      "Grep",
      "Bash(open:*)"
    ],
    "denyTools": [
      "mcp__confluence__confluence_execute_cql_search",
      "mcp__confluence__confluence_get_current_user",
      "mcp__sensors__list_events_all",
      "mcp__sensors__list_event_properties_all",
      "mcp__sensors__list_event_tags"
