      "Edit(/.claude/session-state.md)",
      "Bash(git -C /Users/felix.zhi/pm-workspace-public status)",
      "Bash(brew tap *)",
      "Bash(brew install *)",
      "Edit(/.claude/skills/data-report/**)"
