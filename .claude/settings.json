    "additionalDirectories": [
      "/Users/felix.zhi/pm-workspace-public/examples",
      "/Users/felix.zhi/.browser-use",
      "/Users/felix.zhi/pm-workspace/.claude/commands",
      "/Users/felix.zhi/pm-workspace/projects/growth/activity-center/screenshots/prd/flowchart",
