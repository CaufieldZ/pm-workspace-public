#!/usr/bin/env bash
# 防腐化 hook：Skill/规则文件变更时自动跑轻量审计 + secret scan
# 激活方式：git config core.hooksPath .githooks

# -------- Secret scan（所有 commit 都跑）--------
# 匹配常见真 token 格式；占位符（figd_***  / figd_xxx）和 REDACTED 标记不会误伤
SECRET_PATTERNS='figd_[A-Za-z0-9_-]{30,}|xoxb-[0-9]+-[0-9]+-[A-Za-z0-9]+|sk-ant-api[0-9]{2}-[A-Za-z0-9_-]{80,}|ghp_[A-Za-z0-9]{36}|github_pat_[A-Za-z0-9_]{80,}|AKIA[0-9A-Z]{16}|fc-[a-f0-9]{32}|AIza[0-9A-Za-z_-]{35}'

LEAKS=$(git diff --cached -U0 --diff-filter=ACMR | perl -ne 'next unless /^\+/ && !/^\+\+\+/; next if /REDACTED/; print if /(?:'"$SECRET_PATTERNS"')/')

if [ -n "$LEAKS" ]; then
  echo "❌ 检测到疑似 secret 即将入库："
  echo ""
  echo "$LEAKS"
  echo ""
  echo "若为真 secret：① 立即 revoke ② git reset 该文件 ③ 改走本地/env 变量"
  echo "若确为占位符：加 REDACTED 标注或放到 .mcp.json 等已 gitignore 的文件"
  exit 1
fi

CHANGED=$(git diff --cached --name-only --diff-filter=ACMR)

NEEDS_AUDIT=false
echo "$CHANGED" | grep -qE '^\.claude/skills/|^\.claude/rules/|^CLAUDE\.md$' && NEEDS_AUDIT=true

if [ "$NEEDS_AUDIT" = false ]; then
  exit 0
fi

echo "🔍 检测到 Skill/规则文件变更，运行防腐化审计..."
echo ""

bash .claude/skills/workspace-audit/scripts/audit.sh 1,2,3,4,7,12,13,14

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ 审计不通过，commit 被拦截。请修复后重新 commit。"
  exit 1
fi

echo ""
echo "✅ 审计通过"
exit 0
